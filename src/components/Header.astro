---
---
<header class="header-container animate-fade-in">
  <div class="top-bar">
    <div class="container top-bar-content">
      <div class="top-bar-item">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <span>Inscripción Segura · Soporte Continuo</span>
      </div>
      <div class="top-bar-item hide-mobile">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        <span>Encriptación de 256 bits SSL</span>
      </div>
    </div>
  </div>
  <div class="main-header">
    <div class="container main-header-content">
      <a href="/" class="logo-link">
        <img src="/logo.webp" alt="Logo" class="logo-img" />
        <span class="logo-text">Instituto Osbord LLC</span>
      </a>
      <div class="header-badge hide-mobile">
        <span class="badge badge-navy">Inscripciones Abiertas</span>
      </div>
    </div>
  </div>
</header>

<style>
  .header-container {
    width: 100%;
    z-index: 100;
  }
  .top-bar {
    background-color: var(--gold);
    color: var(--navy-deep);
    padding: 0.5rem 0;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .top-bar-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .top-bar-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .main-header {
    background-color: var(--navy-deep);
    border-bottom: 1px solid rgba(197, 160, 89, 0.2);
    padding: 1rem 0;
  }
  .main-header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }
  .logo-img {
    height: 60px;
    width: auto;
    object-fit: contain;
    display: block;
  }
  .logo-text {
    font-family: var(--font-heading);
    font-size: 1.30rem;
    font-weight: 700;
    color: var(--white);
    letter-spacing: 0.02em;
  }
  .icon {
    width: 1rem;
    height: 1rem;
  }
  @media (max-width: 768px) {
    .main-header {
      padding: 0.75rem 0;
    }
    .logo-link {
      gap: 0.5rem;
    }
    .logo-img {
      height: 38px;
    }
    .logo-text {
      font-size: 1.05rem;
    }
    .hide-mobile {
      display: none;
    }
    .top-bar-content {
      justify-content: center;
    }
  }
</style>
