---
interface Props {
  plan: 'pago-unico' | 'financiamiento-4' | 'financiamiento-6';
  planName: string;
}

const { plan, planName } = Astro.props;
---

<div id="email-modal" class="modal-overlay hidden">
  <div class="modal-card animate-scale-in">
    <button id="close-modal-btn" class="close-btn" aria-label="Cerrar modal">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    
    <div class="modal-header">
      <div class="lock-icon-container">
        <svg class="lock-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>
      <h3 class="modal-title">Inscripción Segura</h3>
      <p class="modal-subtitle">Estás adquiriendo: <strong class="text-gold">{planName}</strong></p>
    </div>

    <form id="payment-form" class="modal-form">
      <input type="hidden" name="plan" value={plan} />
      
      <div class="form-group">
        <label for="email" class="form-label">Correo Electrónico del Alumno</label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          required 
          placeholder="nombre@ejemplo.com" 
          class="form-input" 
        />
        <p class="form-help">Utiliza este email para acceder a tus contenidos tras el pago.</p>
      </div>

      <button type="submit" id="submit-btn" class="btn btn-gold btn-full">
        <span id="btn-text">Proceder al Pago Seguro</span>
        <span id="btn-spinner" class="spinner hidden"></span>
      </button>

      <div class="secure-footer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shield-icon">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <span>Encriptación SSL 256 bits · Stripe Checkout</span>
      </div>
    </form>
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(13, 27, 42, 0.85);
    backdrop-filter: blur(4px);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
    transition: opacity var(--transition-base);
  }
  .modal-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }
  .modal-card {
    background: var(--white);
    border-radius: var(--radius-xl);
    padding: var(--space-2xl);
    width: 100%;
    max-width: 460px;
    box-shadow: var(--shadow-xl), 0 0 0 1px rgba(197, 160, 89, 0.1);
    position: relative;
    border: 1px solid var(--gray-200);
  }
  .close-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gray-400);
    border-radius: var(--radius-full);
    transition: all var(--transition-fast);
  }
  .close-btn:hover {
    background-color: var(--gray-100);
    color: var(--navy);
  }
  .close-btn svg {
    width: 1.25rem;
    height: 1.25rem;
  }
  .modal-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }
  .lock-icon-container {
    width: 3.5rem;
    height: 3.5rem;
    background-color: var(--gold-glow);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-md);
  }
  .lock-icon {
    width: 1.75rem;
    height: 1.75rem;
    color: var(--gold);
  }
  .modal-title {
    font-size: 1.5rem;
    color: var(--navy);
    margin-bottom: 0.25rem;
  }
  .modal-subtitle {
    font-size: 0.9rem;
    color: var(--gray-500);
  }
  .modal-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .form-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--navy);
  }
  .form-input {
    border: 1px solid var(--gray-300);
    border-radius: var(--radius-lg);
    padding: 0.85rem var(--space-md);
    font-size: 1rem;
    color: var(--text-dark);
    transition: all var(--transition-base);
  }
  .form-input:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px var(--gold-glow);
  }
  .form-help {
    font-size: 0.75rem;
    color: var(--gray-400);
  }
  .secure-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    font-size: 0.75rem;
    color: var(--gray-500);
    margin-top: var(--space-sm);
  }
  .shield-icon {
    width: 0.9rem;
    height: 0.9rem;
    color: var(--gold);
  }
  .spinner {
    display: inline-block;
    width: 1.25rem;
    height: 1.25rem;
    border: 3px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    border-top-color: var(--white);
    animation: spin 1s ease-in-out infinite;
  }
  .spinner.hidden {
    display: none;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  @media (max-width: 480px) {
    .modal-card {
      padding: var(--space-lg);
      margin: 0 var(--space-md);
      width: calc(100% - 2rem);
    }
    .modal-title {
      font-size: 1.35rem;
    }
  }
</style>

<script>
  const modal = document.getElementById('email-modal');
  const closeBtn = document.getElementById('close-modal-btn');
  const form = document.getElementById('payment-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const btnText = document.getElementById('btn-text');
  const btnSpinner = document.getElementById('btn-spinner');

  if (closeBtn && modal) {
    closeBtn.addEventListener('click', () => {
      modal.classList.add('hidden');
    });

    window.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.add('hidden');
      }
    });
  }

  if (form && submitBtn && btnText && btnSpinner) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Activar loading
      submitBtn.disabled = true;
      btnText.textContent = 'Procesando...';
      btnSpinner.classList.remove('hidden');

      const formData = new FormData(form);
      const email = formData.get('email');
      const plan = formData.get('plan');

      try {
        const response = await fetch('/api/crear-pago', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ email, plan }),
        });

        const data = await response.json();
        
        if (data.url) {
          window.location.href = data.url;
        } else {
          alert('Ocurrió un error al procesar el pago. Por favor intenta de nuevo.');
          resetBtn();
        }
      } catch (err) {
        console.error('Error al iniciar pago:', err);
        alert('Error en el servidor al intentar conectar con la pasarela.');
        resetBtn();
      }
    });
  }

  function resetBtn() {
    if (submitBtn && btnText && btnSpinner) {
      submitBtn.disabled = false;
      btnText.textContent = 'Proceder al Pago Seguro';
      btnSpinner.classList.add('hidden');
    }
  }
</script>
