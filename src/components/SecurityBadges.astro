---
---
<div class="security-badges-container animate-fade-in">
  <div class="badge-item">
    <div class="badge-icon-wrapper">
      <svg class="badge-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </div>
    <div class="badge-text-wrapper">
      <h4>Pago 100% Seguro</h4>
      <p>Procesado de forma nativa por Stripe</p>
    </div>
  </div>

  <div class="badge-item">
    <div class="badge-icon-wrapper">
      <svg class="badge-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
    </div>
    <div class="badge-text-wrapper">
      <h4>Encriptación SSL</h4>
      <p>Protección cifrada de 256 bits</p>
    </div>
  </div>
</div>

<style>
  .security-badges-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-2xl);
    flex-wrap: wrap;
    margin: var(--space-xl) 0;
  }
  .badge-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    background-color: var(--white);
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
    min-width: 260px;
  }
  .badge-icon-wrapper {
    width: 2.75rem;
    height: 2.75rem;
    background-color: var(--gold-glow);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .badge-svg {
    width: 1.35rem;
    height: 1.35rem;
    color: var(--gold);
  }
  .badge-text-wrapper h4 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 0.15rem;
  }
  .badge-text-wrapper p {
    font-size: 0.75rem;
    color: var(--gray-500);
    margin: 0;
  }
  @media (max-width: 768px) {
    .security-badges-container {
      gap: var(--space-md);
    }
    .badge-item {
      width: 100%;
    }
  }
</style>
